# AI Agent Terminal & Sandbox v2.0 Environment Variables

# App Configuration
APP_ENV=production
DEBUG=false
LOG_LEVEL=info

# Security (CHANGE THESE!)
API_KEY=your-super-secret-api-key-here
JWT_SECRET=your-jwt-secret-here

# Database
DATABASE_URL=sqlite+aiosqlite:///data/app.db

# Redis (for multi-machine coordination)
REDIS_URL=redis://localhost:6379/0

# Volumes (Fly.io persistent storage)
VOLUME_PATH=/data
SANDBOX_DIR=/data/sandbox
SESSIONS_DIR=/data/sessions
TOOLS_DIR=/data/tools
LOGS_DIR=/data/logs
BACKUPS_DIR=/data/backups

# Persistence
PERSIST_SESSIONS=true
SESSION_TIMEOUT=3600

# Sandbox
SANDBOX_TIMEOUT=300
MAX_CONCURRENT_SESSIONS=50
MAX_FILE_SIZE=104857600

# Auto-installation
AUTO_INSTALL_TOOLS=true
AUTO_INSTALL_TIMEOUT=300

# Browser
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000
BROWSER_VIEWPORT_WIDTH=1920
BROWSER_VIEWPORT_HEIGHT=1080

# Fly.io (auto-populated)
FLY_REGION=iad
FLY_ALLOC_ID=
FLY_APP_NAME=ai-agent-terminal
